<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <fieldset name="sales_methods">
        <settings>
            <label translate="true">Sales Methods</label>
        </settings>

        <field name="payment_methods" formElement="multiselect" sortOrder="10">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Payment Methods</label>
                <dataScope>payment_methods</dataScope>
                <notice translate="true">Select the payment methods available for this company. Leave empty to allow all methods.</notice>
            </settings>
            <formElements>
                <multiselect>
                    <settings>
                        <options class="Orangecat\CompanyMethods\Model\Config\Source\PaymentMethods"/>
                    </settings>
                </multiselect>
            </formElements>
        </field>

        <field name="shipping_methods" formElement="multiselect" sortOrder="20">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Shipping Methods</label>
                <dataScope>shipping_methods</dataScope>
                <notice translate="true">Select the shipping methods available for this company. Leave empty to allow all methods.</notice>
            </settings>
            <formElements>
                <multiselect>
                    <settings>
                        <options class="Orangecat\CompanyMethods\Model\Config\Source\ShippingMethods"/>
                    </settings>
                </multiselect>
            </formElements>
        </field>

    </fieldset>
</form>
